# Backend environment variables
# Copy this to .env and fill in your values

# MongoDB Atlas connection string
# Get this from: Atlas Dashboard → Connect → Connect your application
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://TunidataCompass:11647436Bonjour.@cluster0.jylqelz.mongodb.net/?appName=Cluster0

# Database name (will be created automatically)
MONGO_DB=compass

# JWT secret — use a long random string in production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
#SECRET_KEY=change-me-to-a-very-long-random-secret-string

# Path to jobs CSV
CSV_PATH=./data/jobs.csv
